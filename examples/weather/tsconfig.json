{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "node",
    "types": [],
    "skipLibCheck": true,

    // Cloesce required options
    "resolveJsonModule": true,
    "paths": {
      "@data/*": ["./src/data/*"],
      "@cloesce/*": ["./.cloesce/*"],
    },
    "outDir": "dist",
  },
  "include": [".cloesce/*.ts", "src/**/*.ts", "test/**/*.ts"],
}
