        const value = (implObj as any)[key];
        if (value && typeof value === "object" && !Array.isArray(value)) {
            sources[key] = value;
            delete base[key];
        } else if (typeof value === "function") {
            base[key] = value.bind(base);
        }
    }
    if (Object.keys(sources).length > 0) {
        registerDataSourceImpls(modelName, sources);
    }
    return base;
}

