/** @internal */
function _impl(modelName: string, extras: Record<string, any>, implObj: any) {
    const base: any = { ...implObj, ...extras, tag: modelName };
    for (const key of Object.keys(base)) {
        const v = base[key];
        if (typeof v === "function") base[key] = v.bind(base);
    }
    return base;
}

/** @internal */
function _implDs(generated: Record<string, any>, user: Record<string, any>) {
    const merged: any = { ...generated, ...user };
    for (const key of Object.keys(merged)) {
        const v = merged[key];
        if (typeof v === "function") merged[key] = v.bind(merged);
    }
    return merged;
}

import cidl from "./cidl.json" with { type: "json" };

/**
 * Build the Cloesce application. Upgrades {@link CfEnv} and wires up routing.
 *
 * Two forms:
 * - **Worker entrypoint**: `cloesce(env)`.
 * - **Durable Object constructor**: `cloesce(env, this, [migrations])`. Attaches the
 *   Cloesce executor endpoints to your class (lazily, on the prototype — workerd RPC
 *   does not expose instance properties) and applies DO SQLite migrations once via
 *   `blockConcurrencyWhile`. Your class may extend any `DurableObject` subclass;
 *   Cloesce is not part of the inheritance chain.
 *
 * @param env - The raw Cloudflare Workers environment.
 * @param host - Inside a Durable Object constructor: `this`.
 * @param migrations - DO SQLite migrations to apply on first construction.
 * @returns A {@link CloesceApp} ready to handle requests via `app.run(request)`.
 *
 * @example Custom fetch handler
 * ```ts
 * export default {
 *   async fetch(request: Request, env: CfEnv): Promise<Response> {
 *     const app = cloesce(env);
 *     return app.run(request);
 *   },
 * };
 * ```
 *
 * @example Durable Object
 * ```ts
 * export class MyDo extends DurableObject<CfEnv> {
 *   private app: CloesceApp;
 *
 *   constructor(ctx: DurableObjectState, env: CfEnv) {
 *     super(ctx, env);
 *     this.app = cloesce(env, this, [myMigration]);
 *     this.app.register(MyModel);
 *   }
 *
 *   async fetch(request: Request): Promise<Response> {
 *     return await this.app.run(request);
 *   }
 * }
 * ```
 */
export function cloesce(env: CfEnv): CloesceApp;
export function cloesce(env: CfEnv, host: object, migrations?: DurableMigration[]): CloesceApp;
export function cloesce(env: CfEnv, host?: object, migrations: DurableMigration[] = []): CloesceApp {
    if (host !== undefined) {
        const ctx = (host as { ctx?: DurableObjectState }).ctx;
        if (ctx === undefined) {
            throw new Error("cloesce(env, host): host has no `ctx`; pass `this` from a class extending DurableObject.");
        }
        const proto = Object.getPrototypeOf(host);
        if (!proto.__cloesceSqlBatch) {
            proto.__cloesceSqlBatch = function (this: { ctx: DurableObjectState }, statements: { sql: string, bindings: unknown[] }[]) {
                return durableSqlBatch(this.ctx.storage, statements);
            };
            proto.__cloesceKvGet = function (this: { ctx: DurableObjectState }, key: string) {
                return this.ctx.storage.kv.get(key) ?? null;
            };
            proto.__cloesceKvGetMany = function (this: { ctx: DurableObjectState }, keys: string[]) {
                return keys.map((key) => [key, this.ctx.storage.kv.get(key) ?? null]);
            };
            proto.__cloesceKvPut = function (this: { ctx: DurableObjectState }, key: string, value: unknown) {
                this.ctx.storage.kv.put(key, value);
            };
        }
        if (migrations.length > 0) {
            ctx.blockConcurrencyWhile(() => applyDurableMigrations(ctx.storage, migrations));
        }
    }
    // @ts-expect-error
    return new CloesceApp(cidl as any, "{{ worker_url }}", upgradeEnv(env), host);
}

// Default entrypoint for a Cloesce app.
// Replace with a custom fetch handler to register API implementations, add middleware, etc.
export default {
    async fetch(request: Request, env: CfEnv): Promise<Response> {
        const app = cloesce(env);
        return await app.run(request);
    }
}
