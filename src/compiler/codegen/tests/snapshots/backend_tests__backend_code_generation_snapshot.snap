export abstract class BasicService {
    readonly tag = "BasicService";
    abstract init(self: BasicService): MaybePromise<HttpResult<void> | void>;
    abstract downloadData(): MaybePromise<HttpResult<ReadableStream>>;
    abstract instanceMethod(input: number): MaybePromise<HttpResult<number>>;
    abstract staticMethod(input: string): MaybePromise<HttpResult<string>>;
    abstract uploadData(data: ReadableStream): MaybePromise<HttpResult<boolean>>;
}

