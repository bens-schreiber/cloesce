// A handle alias is emitted for every binding (even one that hosts no model), so a route
// that injects a raw KV/R2/DO binding still has a type to reference.
// These should not be used directly; use the `Env` namespace instead.
export type Db_db<E> = Env.db & {
    hasSqlColumnTypes: Needs<E, "db", HasSqlColumnTypesStore<E>>;
    modelWithCompositePk: Needs<E, "db", ModelWithCompositePkStore<E>>;
    modelWithKv: Needs<E, "db", ModelWithKvStore<E>>;
    modelWithR2: Needs<E, "db", ModelWithR2Store<E>>;
    oneToManyModel: Needs<E, "db", OneToManyModelStore<E>>;
    toyotaPrius: Needs<E, "db", ToyotaPriusStore<E>>;
    basicModel: Needs<E, "db", BasicModelStore<E>>;
    modelWithCustomDs: Needs<E, "db", ModelWithCustomDsStore<E>>;
    hasOneToOne: Needs<E, "db", HasOneToOneStore<E>>;
    modelWithCruds: Needs<E, "db", ModelWithCrudsStore<E>>;
};
export type Kv_MyKv<E> = Env.MyKv & {
};
export type R2_MyR2<E> = Env.MyR2 & {
};
export type Do_GlobalDo<E> = Env.GlobalDo & {
    globalSettings: Needs<E, "globalDo", GlobalSettingsStore<E>>;
};
export type Do_LeaderboardDo<E> = Env.LeaderboardDo & {
    leaderboard: Needs<E, "leaderboardDo", LeaderboardStore<E>>;
    leaderboardEntry: Needs<E, "leaderboardDo", LeaderboardEntryStore<E>>;
};

/**
 * The fully-upgraded Cloesce environment. Contains:
 * - every binding (camelCased, e.g. `env.subRedditDb`) and injectable
 * - each binding carrying its model stores
 * - each unbacked model's store, directly (e.g. `env.Foo` for a model with no D1/DO binding)
 *
 * Bindings are reached only under their camelCased name; the raw `wrangler.toml` (capitalized)
 * keys are omitted from `CfEnv` here, leaving Cloesce's own vars/injectables intact.
 */
export type FullEnv = Omit<CfEnv, never | "db" | "MyKv" | "MyR2" | "GlobalDo" | "LeaderboardDo"> & {
    RouteCar: RouteCarStore<FullEnv>;
    RouteOwner: RouteOwnerStore<FullEnv>;
    db: Db_db<FullEnv>;
    myKv: Env.MyKv;
    myR2: Env.MyR2;
    globalDo: Do_GlobalDo<FullEnv>;
    leaderboardDo: Do_LeaderboardDo<FullEnv>;
    YouTubeApi: YouTubeApi;
};

export namespace Env {
    export interface BasicServiceTopScores {
        leaderboardDo: Do_LeaderboardDo<BasicServiceTopScores>;
    }
    export interface BasicServiceGlobalConfig {
        globalDo: Do_GlobalDo<BasicServiceGlobalConfig>;
    }
    export interface ModelWithCompositePkInstanceMethod {
        db: Db_db<ModelWithCompositePkInstanceMethod>;
    }
    export interface ModelWithKvInstanceMethod {
        db: Db_db<ModelWithKvInstanceMethod>;
    }
}

export namespace Api {
    export namespace BasicService {
        export type downloadData = () => Awaitable<HttpResult<ReadableStream> | ReadableStream>;
        export type instanceMethod = (input: number) => Awaitable<HttpResult<number> | number>;
        export type staticMethod = (input: string) => Awaitable<HttpResult<string> | string>;
        export type uploadData = (data: ReadableStream) => Awaitable<HttpResult<boolean> | boolean>;
        export type topScores = (env: Env.BasicServiceTopScores, tenantId: number) => Awaitable<HttpResult<unknown> | unknown>;
        export type globalConfig = (env: Env.BasicServiceGlobalConfig) => Awaitable<HttpResult<unknown> | unknown>;
        export type Of = { downloadData: downloadData; instanceMethod: instanceMethod; staticMethod: staticMethod; uploadData: uploadData; topScores: topScores; globalConfig: globalConfig };
    }
    export namespace GlobalSettings {
        export type Of = {  };
    }
    export namespace HasSqlColumnTypes {
        export type Of = {  };
    }
    export namespace Leaderboard {
        export type Of = {  };
    }
    export namespace LeaderboardEntry {
        export type Of = {  };
    }
    export namespace ModelWithCompositePk {
        export type instanceMethod = (self: ModelWithCompositePk, env: Env.ModelWithCompositePkInstanceMethod, input: string) => Awaitable<HttpResult<string> | string>;
        export type Of = { instanceMethod: instanceMethod };
    }
    export namespace ModelWithKv {
        export type instanceMethod = (self: ModelWithKv, env: Env.ModelWithKvInstanceMethod, input: string) => Awaitable<HttpResult<string> | string>;
        export type staticMethod = (input: number) => Awaitable<HttpResult<number> | number>;
        export type hasKvParamAndRes = (self: ModelWithKv, input: KValue<string>) => Awaitable<HttpResult<KValue<string>> | KValue<string>>;
        export type Of = { instanceMethod: instanceMethod; staticMethod: staticMethod; hasKvParamAndRes: hasKvParamAndRes };
    }
    export namespace ModelWithR2 {
        export type hasR2ParamAndRes = (self: ModelWithR2, input: R2ObjectBody) => Awaitable<HttpResult<R2ObjectBody> | R2ObjectBody>;
        export type Of = { hasR2ParamAndRes: hasR2ParamAndRes };
    }
    export namespace OneToManyModel {
        export type Of = {  };
    }
    export namespace RouteCar {
        export type Of = {  };
    }
    export namespace RouteOwner {
        export type instanceMethod = (self: RouteOwner, input: string) => Awaitable<HttpResult<string> | string>;
        export type Of = { instanceMethod: instanceMethod };
    }
    export namespace ToyotaPrius {
        export type instanceMethod = (self: ToyotaPrius, input: string) => Awaitable<HttpResult<string> | string>;
        export type Of = { instanceMethod: instanceMethod };
    }
    export namespace BasicModel {
        export type Of = {  };
    }
    export namespace ModelWithCustomDs {
        export type instanceMethod = (self: ModelWithCustomDs, input: string) => Awaitable<HttpResult<string> | string>;
        export interface Custom {
            get(id: number, externalParam: string): Promise<HttpResult<ModelWithCustomDs>>;
        }
        export type Of = { instanceMethod: instanceMethod; Custom: Custom };
    }
    export namespace HasOneToOne {
        export type Of = {  };
    }
    export namespace ModelWithCruds {
        export interface ByName {
            get(name: string): Promise<HttpResult<ModelWithCruds>>;
            list(name: string, limit: number): Promise<HttpResult<ModelWithCruds[]>>;
        }
        export type Of = { ByName: ByName };
    }
}
