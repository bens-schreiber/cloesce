            listPlan: {"stages":[{"steps":[{"query":{"Sql":{"arguments":[{"spread":false,"value":{"Param":"lastSeen_id"}},{"spread":false,"value":{"Param":"limit"}}],"database":{"kind":"D1","name":"db"},"mapping":{"cardinality":"Many","join":[]},"route_fields":[],"shard":[],"sql":[{"Literal":"SELECT \"id\", \"name\", \"categoryId\" FROM \"ModelWithCruds\" WHERE \"id\" > "},{"Bind":0},{"Literal":" ORDER BY \"id\" ASC LIMIT "},{"Bind":1}]}},"table":0}]}],"tables":[{"parent":null}]} as SelectPlan,

            /**
             * Load all matching `ModelWithCruds` rows.
             *
             * ```
             * SELECT PLAN (LIST) `ModelWithCruds` · 1 stage · 1 step
             *
             * STAGE 0
             * └─ SEARCH `ModelWithCruds` ON d1 `db` LIMIT `$limit` MANY
             * ```
             *
             * @returns An {@link HttpResult} with the rows, or 400 on validation errors.
             */
            async list(env: { db: Env.db }, lastSeen_id: number, limit: number): Promise<HttpResult<Self[]>> {
                const params = { lastSeen_id, limit };
                const res = await CloesceOrm.fromEnv(env).list<Self>(Meta, params, this.tree, this.listPlan);
                if (res.errors.length > 0) {
                    return HttpResult.fail(400, CloesceError.displayErrors(res));
                }
                return HttpResult.ok(200, res.value!);
            },

            /**
             * Hydrate pre-supplied ("seeded") `ModelWithCruds` rows against {@link listPlan}.
             *
             * The seeded `rows` become the complete root set, so the root fetch is skipped and
             * no seek/filter params are needed. Any relation present on a seeded row (including
             * `[]`) is authoritative and its fetch step is skipped for every parent; unseeded
             * relations are fetched off the plan.
             *
             * @remarks
             * - **Seeds are consumed.** Rows are mutated in place (shard/route fields stamped,
             *   children attached). Do not reuse a seed array after hydrating.
             * - **Join keys are required.** Seeded rows must carry the join keys for any unseeded
             *   child path, or those children silently come back empty.
             * - **JSON transport drops `undefined`.** A relation dropped in transit on some rows
             *   still counts as seeded if any row kept it; those rows degrade to empty, not an error.
             *
             * @returns An {@link HttpResult} with the hydrated rows, or 400 on validation errors.
             */
            async hydrateAll(
                env: { db: Env.db }, 
                rows: DeepPartial<Self>[]): Promise<HttpResult<Self[]>> {
                const res = await CloesceOrm.fromEnv(env).hydrateAll<Self>(Meta, rows, this.tree, this.listPlan, {  });
                if (res.errors.length > 0) {
                    return HttpResult.fail(400, CloesceError.displayErrors(res));
                }
                return HttpResult.ok(200, res.value!);
            },

            /**
             * Hydrate a single pre-supplied ("seeded") `ModelWithCruds` row against {@link listPlan}.
             *
             * As {@link hydrateAll}, but for one row. Returns 404 when the hydrated row is `null`.
             *
             * @remarks
             * - **Seed is consumed.** The row is mutated in place. Do not reuse it after hydrating.
             * - **Join keys are required.** The seeded row must carry the join keys for any unseeded
             *   child path, or those children silently come back empty.
             * - **JSON transport drops `undefined`.** A relation dropped in transit degrades to
             *   empty rather than being refetched.
             *
             * @returns An {@link HttpResult} with the hydrated row, 404 if null, or 400 on validation errors.
             */
            async hydrate(
                env: { db: Env.db }, 
                row: DeepPartial<Self>): Promise<HttpResult<Self>> {
                const res = await CloesceOrm.fromEnv(env).hydrate<Self>(Meta, row, this.tree, this.listPlan, {  });
                if (res.errors.length > 0) {
                    return HttpResult.fail(400, CloesceError.displayErrors(res));
                }
                if (res.value === null) {
                    return HttpResult.fail(404);
                }
                return HttpResult.ok(200, res.value);
            },

            /**
             * Insert or update a `ModelWithCruds` and its included relations.
             *
             * The save plan is computed at runtime from the payload's shape.
             *
             * @returns An {@link HttpResult} with the saved row, 404 if the target vanished, or 400 on validation errors.
             */
            async save(env: { db: Env.db }, model: DeepPartial<ModelWithCruds.Self>): Promise<HttpResult<Self | null>> {
                const res = await CloesceOrm.fromEnv(env).save<Self>(Meta, { ...model } as DeepPartial<Self>, this.tree);
                if (res.errors.length > 0) {
                    return HttpResult.fail(400, CloesceError.displayErrors(res));
                }
                if (res.value === null) {
                    return HttpResult.fail(404);
                }
                return HttpResult.ok(200, res.value);
            },
        };
    }
    /** The `ByName` data source with custom CRUD you must implement via {@link ByName.impl}. */
    export namespace ByName {
        /** Custom CRUD operations to implement. Generated operations are inherited automatically. */
        export interface Crud {
            get(name: string): ApiResult<Self>;
            list(name: string, limit: number): ApiResult<Self[]>;
        }
        /** The full `ByName` data source: generated operations plus your {@link Crud}. */
        export type Impl = typeof GeneratedSource.ByName & Crud;
        /**
         * Provide custom CRUD. Use `this` to call generated operations (e.g. `this.tree`).
         *
         * @param implObj - Object implementing the stubbed {@link Crud} methods.
         * @returns The merged data source with generated + custom operations.
         *
         * @example
         * ```ts
         * const ByName = clo.ModelWithCruds.ByName.impl({
         *   async get(env, id) {
         *     const include = this.tree;
         *     // custom logic...
         *   },
         * });
         *
         * export const ModelWithCruds = clo.ModelWithCruds.impl({
         *   ByName,
         *   // ...other Api methods
         * });
         * ```
         */
        export function impl<I extends Crud>(implObj: I & ThisType<typeof GeneratedSource.ByName & I>): typeof GeneratedSource.ByName & I {
            return _implDs(GeneratedSource.ByName, implObj);
        }
    }

    /**
     * Register your implementation of `ModelWithCruds`.
     *
     * Use `this` to call sibling methods and access generated data sources.
     *
     * @param implObj - Object implementing each {@link Api} method and any custom {@link Sources}.
     * @returns The bound implementation that Cloesce dispatches requests to.
     *
     * @example
     * ```ts
     * export const ModelWithCruds = clo.ModelWithCruds.impl({
     *   async myApi(self, env, arg) {
     *     const res = await ModelWithCruds.Default.get(env, arg);
     *     return res.data!;
     *   },
     * });
     * ```
     */
    export function impl<Impl extends Api & Sources>(implObj: Impl & ThisType<{ tag: string; Orm: typeof Orm; Default: typeof GeneratedSource.Default } & Impl>): { tag: string; Orm: typeof Orm; Default: typeof GeneratedSource.Default } & Impl {
        return _impl("ModelWithCruds", { Orm, Default: GeneratedSource.Default }, implObj) as any;
    }

    /**
     * Lower-level ORM access with explicit {@link IncludeTree}. Returns raw `CloesceResult`.
     *
     * Prefer data sources (e.g. `ModelWithCruds.Default.save(...)`) unless you need a custom tree.
     *
     * These wrappers accept arbitrary include trees, so unlike the generated data sources they
     * always fall back to runtime WASM planning rather than a precompiled plan.
     */
    export namespace Orm {
        /**
         * Insert or update `ModelWithCruds` and its included relations.
         *
         * @param env - Environment with the required database binding(s).
         * @param newModel - Partial row data to save.
         * @param include - Include tree controlling which relations to persist. Defaults to `Default.tree`.
         * @returns The saved row, or `null` if the target vanished.
         */
        export async function save(env: { db: Env.db }, newModel: DeepPartial<Self>, include: IncludeTree<Self> = GeneratedSource.Default.tree): Promise<CloesceResult<Self | null>> {
            return await CloesceOrm.fromEnv(env).save<Self>(Meta, newModel, include);
        }

        /**
         * Load a single `ModelWithCruds` by its route/primary key.
         *
         * @param env - Environment with the required binding(s).
         * @param args - Route/primary key fields and an optional `include` tree override.
         */
        export async function get(env: { db: Env.db }, args: { id: number, include?: IncludeTree<Self> }): Promise<CloesceResult<Self | null>> {
            const { include, ...params } = args;
            return await CloesceOrm.fromEnv(env).get<Self>(Meta, params, include ?? GeneratedSource.Default.tree);
        }

        /**
         * Hydrate a single pre-supplied ("seeded") `ModelWithCruds` row, filling only the
         * relations not already present on `row`.
         *
         * The seeded `row` is the complete root, so the root fetch is skipped. Any relation
         * present on it (including `[]`) is authoritative and its fetch is skipped; unseeded
         * relations load off the include tree.
         *
         * @remarks
         * - Seeds are consumed (mutated in place); do not reuse the row after hydrating.
         * - Seeded rows must carry the join keys for any unseeded child path, or those
         *   children come back empty.
         * - JSON transport drops `undefined`, so a relation dropped in transit degrades to
         *   empty rather than being refetched.
         *
         * @param env - Environment with the required binding(s).
         * @param row - Partial row, authoritative as given.
         * @param include - Include tree controlling which relations to load. Defaults to `Default.tree`.
         */
        export async function hydrate(env: { db: Env.db }, row: DeepPartial<Self>, include: IncludeTree<Self> = GeneratedSource.Default.tree): Promise<CloesceResult<Self | null>> {
            return await CloesceOrm.fromEnv(env).hydrate<Self>(Meta, row, include, undefined, {  });
        }

        /**
         * Hydrate many pre-supplied ("seeded") `ModelWithCruds` rows. See {@link hydrate} for
         * seeding semantics.
         *
         * @remarks
         * - Seeds are consumed (mutated in place); do not reuse a rows array after hydrating.
         * - Seeded rows must carry the join keys for any unseeded child path, or those
         *   children come back empty.
         * - JSON transport drops `undefined`, so a relation dropped in transit degrades to
         *   empty rather than being refetched.
         *
         * @param env - Environment with the required binding(s).
         * @param rows - Partial rows, authoritative as given. These become the complete root set.
         * @param include - Include tree controlling which relations to load. Defaults to `Default.tree`.
         */
        export async function hydrateAll(env: { db: Env.db }, rows: DeepPartial<Self>[], include: IncludeTree<Self> = GeneratedSource.Default.tree): Promise<CloesceResult<Self[]>> {
            return await CloesceOrm.fromEnv(env).hydrateAll<Self>(Meta, rows, include, undefined, {  });
        }
    }
}

/** @internal */
function _impl(modelName: string, extras: Record<string, any>, implObj: any) {
    const base: any = { ...implObj, ...extras, tag: modelName };
    for (const key of Object.keys(base)) {
        const v = base[key];
        if (typeof v === "function") base[key] = v.bind(base);
    }
    return base;
}

/** @internal */
function _implDs(generated: Record<string, any>, user: Record<string, any>) {
    const merged: any = { ...generated, ...user };
    for (const key of Object.keys(merged)) {
        const v = merged[key];
        if (typeof v === "function") merged[key] = v.bind(merged);
    }
    return merged;
}

import cidl from "./cidl.json" with { type: "json" };

/**
 * Build the Cloesce application. Upgrades {@link CfEnv} and wires up routing.
 *
 * Two forms:
 * - **Worker entrypoint**: `cloesce(env)`.
 * - **Durable Object constructor**: `cloesce(env, this, [migrations])`. Attaches the
 *   Cloesce executor endpoints to your class (lazily, on the prototype — workerd RPC
 *   does not expose instance properties) and applies DO SQLite migrations once via
 *   `blockConcurrencyWhile`. Your class may extend any `DurableObject` subclass;
 *   Cloesce is not part of the inheritance chain.
 *
 * @param env - The raw Cloudflare Workers environment.
 * @param host - Inside a Durable Object constructor: `this`.
 * @param migrations - DO SQLite migrations to apply on first construction.
 * @returns A {@link CloesceApp} ready to handle requests via `app.run(request)`.
 *
 * @example Custom fetch handler
 * ```ts
 * export default {
 *   async fetch(request: Request, env: CfEnv): Promise<Response> {
 *     const app = cloesce(env);
 *     return app.run(request);
 *   },
 * };
 * ```
 *
 * @example Durable Object
 * ```ts
 * export class MyDo extends DurableObject<CfEnv> {
 *   private app: CloesceApp;
 *
 *   constructor(ctx: DurableObjectState, env: CfEnv) {
 *     super(ctx, env);
 *     this.app = cloesce(env, this, [myMigration]);
 *     this.app.register(MyModel);
 *   }
 *
 *   async fetch(request: Request): Promise<Response> {
 *     return await this.app.run(request);
 *   }
 * }
 * ```
 */
export function cloesce(env: CfEnv): CloesceApp;
export function cloesce(env: CfEnv, host: object, migrations?: DurableMigration[]): CloesceApp;
export function cloesce(env: CfEnv, host?: object, migrations: DurableMigration[] = []): CloesceApp {
    if (host !== undefined) {
        const ctx = (host as { ctx?: DurableObjectState }).ctx;
        if (ctx === undefined) {
            throw new Error("cloesce(env, host): host has no `ctx`; pass `this` from a class extending DurableObject.");
        }
        const proto = Object.getPrototypeOf(host);
        if (!proto.__cloesceSqlBatch) {
            proto.__cloesceSqlBatch = function (this: { ctx: DurableObjectState }, statements: { sql: string, bindings: unknown[] }[]) {
                return durableSqlBatch(this.ctx.storage, statements);
            };
            proto.__cloesceKvGet = function (this: { ctx: DurableObjectState }, key: string) {
                return this.ctx.storage.kv.get(key) ?? null;
            };
            proto.__cloesceKvGetMany = function (this: { ctx: DurableObjectState }, keys: string[]) {
                return keys.map((key) => [key, this.ctx.storage.kv.get(key) ?? null]);
            };
            proto.__cloesceKvPut = function (this: { ctx: DurableObjectState }, key: string, value: unknown) {
                this.ctx.storage.kv.put(key, value);
            };
        }
        if (migrations.length > 0) {
            ctx.blockConcurrencyWhile(() => applyDurableMigrations(ctx.storage, migrations));
        }
    }
    // @ts-expect-error
    return new CloesceApp(cidl as any, "http://example.com/path/to/api", upgradeEnv(env), host);
}

// Default entrypoint for a Cloesce app.
// Replace with a custom fetch handler to register API implementations, add middleware, etc.
export default {
    async fetch(request: Request, env: CfEnv): Promise<Response> {
        const app = cloesce(env);
        return await app.run(request);
    }
}
