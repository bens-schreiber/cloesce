d1 {
    db
}

// #region OneToOne
[crud save, get]
model B for db {
    primary {
        id: int
    }
    
    nav A::bId {
        a
    }
}

api B {
    post testMethod(self)
}

[crud save, get]
model A for db{
    primary {
        id: int
    }
    
    foreign B::id optional  {
        bId
    }

    nav B::id(bId) {
        b
    }
}

source WithB for A {
    include {
        b
    }
}

source WithoutB for A {
    include {}
}

api A {
    [inject db]
    post create(a: A) -> A
    get withoutB([source WithoutB] self) -> A
}
// #endregion
// #region OneToMany
[crud save, get]
model Person for db {
    primary {
        id: int
    }
    
    nav Dog::personId {
        dogs
    }
}

source WithDogs for Person {
    include {
        dogs
    }
}

source WithoutDogs for Person {
    include {}
}

api Person {
    [inject db]
    post create(person: partial<Person>) -> Person
    get withoutDogs([source WithoutDogs] self) -> Person
}

[crud save]
model Dog for db {
    primary {
        id: int
    }
    
    foreign Person::id {
        personId
    }

    nav Person::id(personId) {
        person
    }
}

api Dog {
    post testMethod(self)
}
// #endregion
// #region ManyToMany
[crud save, get]
model Student for db {
    primary {
        id: int
    }
    
    nav CourseStudent::studentId {
        courses
    }
}

source WithCoursesStudentsCourses for Student {
    include {
        courses {
            course {
                students {
                    student {
                        courses
                    }
                }
            }
        }
    }
}

source None for Student {
    include {}
}

api Student {
    [inject db]
    post create(student: partial<Student>) -> Student
    get none([source None] self) -> Student
}

[crud save]
model Course for db {
    primary {
        id: int
    }
    
    nav CourseStudent::courseId {
        students
    }
}

model CourseStudent for db {
    primary {
        foreign Course::id {
            courseId
        }

        foreign Student::id {
            studentId
        }
    }

    nav Course::id(courseId) {
        course
    }

    nav Student::id(studentId) {
        student
    }
}
// #endregion