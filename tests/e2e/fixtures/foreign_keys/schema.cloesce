env { d1 { db } }

//#region OneToOne
[use db, save, get]
model B {
    primary { id: int }

    nav (A::bId) {
        a
    }
}

api B {
    post testMethod(self) -> void
}

[use db, save, get]
model A {
    primary { id: int }

    foreign (B::id) optional {
        bId
        nav { b }
    }
}

source WithB for A {
    include { b }
}

source WithoutB for A {
    include { }
}

api A {
    post create(e: env, a: A) -> A
    get withoutB([source WithoutB] self) -> A
}
//#endregion

//#region OneToMany
[use db, save, get]
model Person {
    primary { id: int }

    nav (Dog::personId) {
        dogs
    }
}

source WithDogs for Person {
    include { dogs }
}

source WithoutDogs for Person {
    include { }
}

api Person {
    post create(e: env, person: Person) -> Person
    get withoutDogs([source WithoutDogs] self) -> Person
}

[use db, save]
model Dog {
    primary { id: int }

    foreign (Person::id) {
        personId
        nav { person }
    }
}

api Dog {
    post testMethod(self) -> void
}
//#endregion

//#region ManyToMany
[use db, save, get]
model Student {
    primary { id: int }

    nav (Course::id) {
        courses
    }
}

source WithCoursesStudentsCourses for Student {
    include { courses { students { courses } } }
}

source None for Student {
    include { }
}

api Student {
    post create(e: env, student: Student) -> Student
    get none([source None] self) -> Student
}

[use db, save]
model Course {
    primary { id: int }

    nav (Student::id) {
        students
    }
}
//#endregion
