d1 {
    db
}

// #region OneToOne
[crud save, get]
model B for db {
    primary {
        id: int
    }

    one A::bId(id) {
        a
    }
}

api B {
    self post testMethod {}
}

[crud save, get]
model A for db{
    primary {
        id: int
    }

    foreign B::id option {
        bId
    }

    one B::id(bId) {
        b
    }
}

source WithB for A {
    include {
        b
    }
}

source WithoutB for A {
    include {}
}

api A {
    post create -> A {
        a: A

        inject { db }
    }
    self(WithoutB) get withoutB -> A {}
}
// #endregion
// #region OneToMany
[crud save, get]
model Person for db {
    primary {
        id: int
    }

    many Dog::personId(id) {
        dogs
    }
}

source WithDogs for Person {
    include {
        dogs
    }
}

source WithoutDogs for Person {
    include {}
}

api Person {
    post create -> Person {
        person: partial<Person>

        inject { db }
    }
    self(WithoutDogs) get withoutDogs -> Person {}
}

[crud save]
model Dog for db {
    primary {
        id: int
    }

    foreign Person::id {
        personId
    }

    one Person::id(personId) {
        person
    }
}

api Dog {
    self post testMethod {}
}
// #endregion
// #region ManyToMany
[crud save, get]
model Student for db {
    primary {
        id: int
    }

    many CourseStudent::studentId(id) {
        courses
    }
}

source WithCoursesStudentsCourses for Student {
    include {
        courses {
            course {
                students {
                    student {
                        courses
                    }
                }
            }
        }
    }
}

source None for Student {
    include {}
}

api Student {
    post create -> Student {
        student: partial<Student>

        inject { db }
    }
    self(None) get none -> Student {}
}

[crud save]
model Course for db {
    primary {
        id: int
    }

    many CourseStudent::courseId(id) {
        students
    }
}

model CourseStudent for db {
    primary {
        foreign Course::id {
            courseId
        }

        foreign Student::id {
            studentId
        }
    }

    one Course::id(courseId) {
        course
    }

    one Student::id(studentId) {
        student
    }
}
// #endregion
