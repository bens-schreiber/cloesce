env {
    d1 { db }
}

[use db]
model NullabilityChecks {
    primary {
        id: int
    }

    notNullableString: string
    nullableString: Option<string>
}

api NullabilityChecks {
    post primitiveTypes(self, a: Option<int>, b: Option<string>) -> Option<bool>
    post modelTypes(self, a: Option<NullabilityChecks>) -> Option<NullabilityChecks>
    post injectableTypes(self) -> void
    post arrayTypes(self, a: Option<Array<int>>, b: Option<Array<NullabilityChecks>>) -> Option<Array<string>>
    post httpResultTypes(self) -> Option<Array<NullabilityChecks>>
}
