env {
    d1 {
        db
    }
    r2 {
        bucket1
        bucket2
    }
}

[use get]
model PureR2Model {
    keyfield {
        id
    }
    
    r2 (bucket1, "path/to/data/{id}") {
        data
    }
    
    r2 (bucket1, "path/to/other/{id}") {
        otherData
    }
    
    r2 (bucket1, "path/") paginated {
        allData
    }
}

api PureR2Model {
    put uploadData(self, e: env, data: stream) -> void
    put uploadOtherData(self, e: env, data: stream) -> void
}

[use db, get, save, list]
model D1BackedModel {
    primary {
        id: int
    }
    
    keyfield {
        keyParam
    }
    
    someColumn: real
    someOtherColumn: string
    
    r2 (bucket1, "d1Backed/{id}/{keyParam}/{someColumn}/{someOtherColumn}") {
        r2Data
    }
}

api D1BackedModel {
    put uploadData(self, e: env, data: stream) -> void
}