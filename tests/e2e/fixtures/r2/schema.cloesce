d1 {
    db
}

r2 bucket1 {
    data {
        id: int
        "path/to/data/{id}"
    }

    otherData {
        id: int
        "path/to/other/{id}"
    }
}


[crud get, save, list]
model D1BackedModel for db {
    primary {
        id: int
    }

    column {
        someColumn: real
        someOtherColumn: string
    }

    r2 bucket1::data(id) {
        someData
    }

    r2 bucket1::otherData(id) {
        someOtherData
    }
}

api D1BackedModel {
    self put uploadData {
        data: stream

        inject { bucket1 }
    }

    self put uploadOtherData {
        data: stream

        inject { bucket1 }
    }
}

[crud get]
model R2Only {
    route {
        id: int
    }

    r2 bucket1::data(id) {
        someData
    }

    one R2Sibling::siblingId(id) {
        sibling
    }
}

api R2Only {
    self put uploadData {
        data: stream

        inject { bucket1 }
    }
}

model R2Sibling {
    route {
        siblingId: int
    }

    r2 bucket1::otherData(siblingId) {
        siblingData
    }
}

api R2Sibling {
    self put uploadData {
        data: stream

        inject { bucket1 }
    }
}
