d1 {
    db
}

r2 bucket1 {
    data(id: string) {
        "path/to/data/{id}"
    }

    otherData(id: string) {
        "path/to/other/{id}"
    }

    allData() paginated {
        "path/"
    }
}


[crud get, save, list]
model D1BackedModel for db {
    primary {
        id: int
    }
    
    column {
        someColumn: real
        someOtherColumn: string
    }
    
    r2 bucket1::data(id) {
        someData
    }

    r2 bucket1::otherData(id) {
        someOtherData
    }
}

api D1BackedModel {
    [inject bucket1]
    put uploadData(self, data: stream)

    [inject bucket1]
    put uploadOtherData(self, data: stream)
}