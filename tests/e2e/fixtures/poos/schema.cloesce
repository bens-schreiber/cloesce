d1 {
    db
}

poo PooA {
    name: string
    major: string
}

poo PooB {
    color: string
}

poo PooC {
    a: PooA
    b: array<PooB>
}

model PooAcceptYield for db {
    primary {
        id: int
    }
}

api PooAcceptYield {
    post acceptPoos(a: PooA, b: PooB, c: PooC)
    post yieldPoo() -> PooC
}