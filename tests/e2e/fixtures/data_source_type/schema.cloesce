env {
    d1 {
        db
    }
}

[use db]
model NoDs {
    primary {
        id: int
    }
}

[use db]
model OneDs {
    primary {
        id: int
    }
}

source ShitAss for OneDs {
    include {}
}

[use db]
model Foo {
    primary {
        id: int
    }
}

api Foo {
    post bar([source Baz] self, customDs: DataSource<Foo>, oneDs: DataSource<OneDs>, noDs: DataSource<NoDs>, poop: Poo)
}

source Baz for Foo {
    include {}
}

poo Poo {
    ds: DataSource<Foo>
}