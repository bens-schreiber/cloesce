d1 {
    db
}

[crud save]
model Topping for db {
    primary {
        id: int
    }
    
    column {
        name: string
    }
    
    nav (Hamburger::id) {
        hamburger
    }
}

[crud save, list]
model Hamburger for db {
    primary {
        id: int
    }
    
    column {
        name: string
    }
    
    nav (Topping::id) {
        toppings
    }
}

source BurgersWithLettuceOrdered for Hamburger {
    include {
        toppings
    }
    
    sql list(lastId: int, limit: int) {
        "
        WITH included as ($include)
        SELECT * FROM included
        WHERE [toppings.name] = 'LETTUCE'
        AND id > $lastId
        ORDER BY id
        LIMIT $limit
        "
    }
}

[internal]
source NoLettuce for Hamburger {
    include {
        toppings
    }
    
    sql get([instance] id: int) {
        "
        WITH included as ($include)
        SELECT * FROM included
        WHERE [toppings.name] != 'LETTUCE'
        AND id = $id
        ORDER BY id
        "
    }
}

[internal]
source OnlyBacon for Hamburger {
    include {
        toppings
    }
    
    sql get([instance] id: int) {
        "
        WITH included as ($include)
        SELECT * FROM included
        WHERE [toppings.name] = 'BACON'
        AND id = $id
        ORDER BY id
        "
    }
}

api Hamburger {
    get noLettuceToppings([source NoLettuce] self) -> array<Topping>
    get onlyBaconToppings([source OnlyBacon] self) -> array<Topping>
}