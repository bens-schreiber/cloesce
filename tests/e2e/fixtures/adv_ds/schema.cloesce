d1 {
    db
}

//#region: Hamburger and Topping Many to Many relationship
[crud save, list]
model Hamburger for db {
    primary {
        id: int
    }

    column {
        name: string
    }

    // Uses the HamburgerTopping join table to get the toppings for a hamburger
    nav HamburgerTopping::hamburgerId {
        toppings
    }
}

api Hamburger {
    get noLettuceToppings([source NoLettuce] self) -> array<Topping>
    get onlyBaconToppings([source OnlyBacon] self) -> array<Topping>
}

[crud save]
model Topping for db {
    primary {
        id: int
    }

    column {
        name: string
    }

    // Uses the HamburgerTopping join table to get the hamburgers for a topping
    nav HamburgerTopping::toppingId {
        hamburgers
    }
}

// Join table for the many-to-many relationship between Hamburger and Topping
model HamburgerTopping for db {
    primary {
        foreign (Hamburger::id) {
            hamburgerId
        }

        foreign (Topping::id) {
            toppingId
        }
    }

    nav Hamburger::id(hamburgerId) {
        hamburger
    }

    nav Topping::id(toppingId) {
        topping
    }
}

source BurgersWithLettuceOrdered for Hamburger {
    include {
        toppings {
            topping
        }
    }

    [inject db]
    list(lastId: int, limit: int)
}

[internal]
source NoLettuce for Hamburger {
    include {
        toppings {
            topping
        }
    }

    [inject db]
    get([instance] id: int)
}

[internal]
source OnlyBacon for Hamburger {
    include {
        toppings {
            topping
        }
    }

    [inject db]
    get([instance] id: int)
}
//#endregion

// Exists to show how the Default data source can be overriden 
[crud save, get, list]
model DefaultOverride for db {
    primary {
        id: int
    }
}

// Overrides the Default data source for DefaultOverride with custom `get` and
// `list` implementations. `save` will still use the default implementation since 
// it's not overridden here.
source Default for DefaultOverride {
    include {}

    [inject db]
    get()

    [inject db]
    list()
}
