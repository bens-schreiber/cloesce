env {
    d1 {
        db
    }
    kv {
        namespace
        otherNamespace
    }
}

[use get, save]
model PureKVModel {
    keyfield {
        id
    }
    
    kv (namespace, "path/to/data/{id}") {
        data: json
    }
    
    kv (otherNamespace, "path/to/other/{id}") {
        otherData: string
    }
}

[use db, get, save, list]
model D1BackedModel {
    primary {
        id: int
    }
    
    keyfield {
        keyParam
    }
    
    someColumn: double
    someOtherColumn: string
    
    kv (namespace, "d1Backed/{id}/{keyParam}/{someColumn}/{someOtherColumn}") {
        kvData: json
    }
}

[use get]
model PaginatedKVModel {
    keyfield {
        id
    }
    
    kv (namespace, "paginated/items/") paginated {
        items: json
    }
}

api PaginatedKVModel {
    post acceptPaginated(ps: Paginated<KvObject<json>>) -> Paginated<KvObject<json>>
}