d1 {
    db
}

kv namespace {
    data(id: int) -> json {
        "path/to/data/{id}"
    }

    paginatedData() -> paginated<json> {
        "path/to/data/"
    }
}

kv otherNamespace {
    otherData(id: int) -> string {
        "path/to/other/{id}"
    }
}

[crud get, save, list]
model ModelWithKv for db {
    primary {
        id: int
    }
    
    kv namespace::data(id) {
        someData
    }

    kv otherNamespace::otherData(id) {
        someOtherData
    }

    kv namespace::paginatedData() {
        paginatedItems
    }

    column {
        someColumn: real
        someOtherColumn: string
    }
}

api ModelWithKv {
    post acceptPaginated(ps: paginated<kvobject<json>>) -> paginated<kvobject<json>>
}

[crud get, save]
model KVOnly {
    route {
        id: int
    }

    kv namespace::data(id) {
        someData
    }

    nav KVSibling::siblingId(id) {
        sibling
    }
}

model KVSibling {
    route {
        siblingId: int
    }

    kv otherNamespace::otherData(siblingId) {
        siblingData
    }
}
