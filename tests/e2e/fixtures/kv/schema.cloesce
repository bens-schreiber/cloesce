d1 {
    db
}

kv namespace {
    data -> json {
        id: int
        "path/to/data/{id}"
    }

    config -> json {
        "config"
    }
}

kv otherNamespace {
    otherData -> string {
        id: int
        "path/to/other/{id}"
    }
}

[crud get, save, list]
model ModelWithKv for db {
    primary {
        id: int
    }

    kv namespace::data(id) {
        someData
    }

    kv otherNamespace::otherData(id) {
        someOtherData
    }

    column {
        someColumn: real
        someOtherColumn: string
    }
}

api ModelWithKv {
    post acceptKvObject -> kvobject<json> {
        item: kvobject<json>
    }
}

[crud get, save]
model KVOnly {
    route {
        id: int
    }

    kv namespace::data(id) {
        someData
    }

    one KVSibling::siblingId(id) {
        sibling
    }
}

model KVSibling {
    route {
        siblingId: int
    }

    kv otherNamespace::otherData(siblingId) {
        siblingData
    }
}

model AppConfig {
    kv namespace::config {
        config
    }
}

[crud get, save]
model KVOnlyWithSingleton {
    route {
        id: int
    }

    kv namespace::data(id) {
        someData
    }

    one AppConfig { appConfig }
}
