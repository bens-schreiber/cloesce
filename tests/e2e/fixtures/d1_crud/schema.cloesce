env {
    d1 {
        db
    }
}

[use db]
[crud save, get, list]
model CrudHaver {
    primary {
        id: int
    }
    
    name: string
}

api CrudHaver {
    post notCrud(self) -> void
}

[use db]
[crud save, get, list]
model Parent {
    primary {
        id: int
    }
    
    foreign (Child::id) optional  {
        favoriteChildId
        
        nav {
            favoriteChild
        }
    }
    
    nav (Child::parentId) {
        children
    }
}

source WithChildren for Parent {
    include {
        children
        favoriteChild
    }
}

[use db]
model Child {
    primary {
        id: int
    }
    
    foreign (Parent::id) {
        parentId
        
        nav {
            parent
        }
    }
}