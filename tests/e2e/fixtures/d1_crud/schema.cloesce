d1 {
    db
}

[crud save, get, list]
model CrudHaver for db {
    primary {
        id: int
    }

    column {
        name: string
    }
}

api CrudHaver {
    self post notCrud {}
}

[crud save, get, list]
model Parent for db {
    primary {
        id: int
    }

    foreign Child::id option {
        favoriteChildId
    }

    one Child::id(favoriteChildId) {
        favoriteChild
    }

    many Child::parentId(id) {
        children
    }
}

source WithChildren for Parent {
    include {
        children
        favoriteChild
    }
}

model Child for db {
    primary {
        id: int
    }

    foreign Parent::id {
        parentId
    }

    one Parent::id(parentId) {
        parent
    }
}
