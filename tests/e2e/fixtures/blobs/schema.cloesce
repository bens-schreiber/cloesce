env {
    d1 {
        db
    }
}

model BlobService {}

api BlobService {
    post incrementBlob(b: blob) -> blob
}

[use db]
[crud save, get, list]
model BlobHaver {
    primary {
        id: int
    }
    
    column {
        blob1: blob
        blob2: blob
    }
}

api BlobHaver {
    get getBlob1(self) -> blob
    post inputStream(s: stream)
    get yieldStream(self) -> stream
}