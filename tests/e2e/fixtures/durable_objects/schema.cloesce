durable LeaderboardDo {
    shard {
        [gt 0]
        tenantId: int
    }

    score() -> int {
        "score"
    }
}

durable GlobalDo {
    config() -> json {
        "config"
    }
}

model Leaderboard {}

api Leaderboard {
    [context LeaderboardDo(tenantId)]
    post setScore(tenantId: int, score: int)

    [context LeaderboardDo(tenantId)]
    get getScore(tenantId: int) -> int
}

model Global {}

api Global {
    [context GlobalDo]
    post setConfig(value: json)

    [context GlobalDo]
    get getConfig() -> json
}
