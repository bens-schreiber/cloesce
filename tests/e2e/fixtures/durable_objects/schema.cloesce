durable LeaderboardDo {
    shard {
        [gt 0]
        tenantId: int
    }

    score() -> int {
        "score"
    }
}

durable GlobalDo {
    config() -> json {
        "config"
    }
}

kv EntryMeta {
    label(tenantId: int, rank: int) -> string {
        "entry/{tenantId}/{rank}"
    }
}

model Leaderboard {}

api Leaderboard {
    [context LeaderboardDo(tenantId)]
    post setScore(tenantId: int, score: int)

    [context LeaderboardDo(tenantId)]
    get getScore(tenantId: int) -> int
}

model Global {}

api Global {
    [context GlobalDo]
    post setConfig(value: json)

    [context GlobalDo]
    get getConfig() -> json
}

// A model BACKED BY a Durable Object: it hydrates its `score` field from the DO's
// own KV storage, and its generated CRUD routes run inside the DO. It inherits
// `tenantId` from the DO's shard and declares an extra `rank` route field.
//
// `meta` is bound to a regular Worker KV namespace, so a single upsert fans out to
// two destinations: `score` to the DO storage, `meta` to Worker KV.
[crud get, save]
model LeaderboardEntry for LeaderboardDo(tenantId) {
    route {
        rank: int
    }

    kv LeaderboardDo::score {
        score
    }

    kv EntryMeta::label(tenantId, rank) {
        meta
    }
}
