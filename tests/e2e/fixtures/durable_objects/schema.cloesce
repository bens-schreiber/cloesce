// #region: Global
durable GlobalDo {
    metadata -> json {
        "metadata"
    }
}

model Global for GlobalDo {
    kv GlobalDo::metadata {
        metadata
    }
}

api Global {
    post newGlobal -> Global {}

    self get getMetadata -> json {}
}
// #endregion

// #region: CRUD and Custom Data Sources
kv GlobalSubRedditMetadata {
    metadata -> json {
        subId: int
        "metadata/{subId}"
    }
}

durable SubRedditDo {
    shard {
        [gt 0]
        id: int
    }

    metadata -> json {
        "metadata"
    }
}

[crud get, save]
model SubReddit for SubRedditDo(subId) {
    kv SubRedditDo::{ metadata, id(subId) } {
        metadata
    }

    kv GlobalSubRedditMetadata::metadata(subId) {
        globalMetadata
    }

    many Post::subId(subId) {
        posts
    }
}

api SubReddit {
    post newSubReddit -> SubReddit {}
    self get feed -> array<Post> {}
}

[crud get, list, save]
model Post for SubRedditDo(subId) {
    primary {
        id: int
    }

    column {
        title: string
        content: string
    }

    many Comment::{postId(id), subId(subId)} {
        comments
    }
}

source Custom for Post {
    include {}

    get {
        id: int
        subId: int
        inject { SubRedditDo }
    }

    list {
        subId: int
        inject { SubRedditDo }
    }

    save {
        post: partial<Post>
        subId: int
        inject { SubRedditDo }
    }
}

[crud get, list, save]
model Comment for SubRedditDo(subId) {
    primary {
        id: int
    }

    column {
        content: string
        upvotes: int
    }

    foreign Post::id {
        postId
    }
}
// #endregion
