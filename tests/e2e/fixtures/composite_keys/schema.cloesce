d1 {
    db
}

[crud get, list, save]
model Student for db {
    primary {
        id: int
        name: string
    }
    
    column {
        favoriteColor: string
    }
    
    // Composite 1:M navigation to StudentCourse join table
    nav (StudentCourse::studentId, StudentCourse::studentName) {
        studentCourses
    }
}

[crud get, list, save]
model Course for db {
    primary {
        id: int
    }
    
    column {
        title: string
    }
    
    nav StudentCourse::courseId {
        studentCourses
    }
}

// A join table with a composite foreign key to Student 
// and a foreign key to Course
[crud get, list, save]
model StudentCourse for db{
    primary {
        // Composite foreign key to Student
        foreign (Student::id, Student::name) {
            studentId
            studentName
        }

        foreign (Course::id) {
            courseId
        }
    }

    // Navigations to Student and Course using the foreign keys
    nav (Student::id(studentId), Student::name(studentName)) {
        student
    }

    nav Course::id(courseId) {
        course
    }
}

source CoursesOrderedDescending for Student {
    include {
        studentCourses
    }

    [inject db]
    list(lastId: int, lastName: string, limit: int)
}

source Default for StudentCourse {
    include {}
}

source WithStudentCourse for StudentCourse {
    include {
        course {
            studentCourses
        }
        student {
            studentCourses
        }
    }
}