d1 {
    db
}

[crud get, list, save]
model Student for db {
    primary {
        id: int
        name: string
    }

    column {
        favoriteColor: string
    }

    // Composite 1:M navigation to StudentCourse join table
    many StudentCourse::{studentId(id), studentName(name)} {
        studentCourses
    }
}

[crud get, list, save]
model Course for db {
    primary {
        id: int
    }

    column {
        title: string
    }

    many StudentCourse::courseId(id) {
        studentCourses
    }
}

// A join table with a composite foreign key to Student
// and a foreign key to Course
[crud get, list, save]
model StudentCourse for db{
    primary {
        // Composite foreign key to Student
        foreign Student::{id, name} {
            studentId
            studentName
        }

        foreign Course::id {
            courseId
        }
    }

    // Navigations to Student and Course using the foreign keys
    one Student::{id(studentId), name(studentName)} {
        student
    }

    one Course::id(courseId) {
        course
    }
}

source CoursesOrderedDescending for Student {
    include {
        studentCourses
    }

    list {
        lastId: int
        lastName: string
        limit: int
        inject { db }
    }
}

source Default for StudentCourse {
    include {}
}

source WithStudentCourse for StudentCourse {
    include {
        course {
            studentCourses
        }
        student {
            studentCourses
        }
    }
}
