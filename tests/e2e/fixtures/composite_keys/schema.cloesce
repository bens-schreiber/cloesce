d1 {
    db
}

[crud get, list, save]
model Student for db {
    primary {
        id: int
        name: string
    }
    
    column {
        favoriteColor: string
    }
    
    nav (StudentCourse::studentId, StudentCourse::studentName) {
        studentCourses
    }
}

source CoursesOrderedDescending for Student {
    include {
        studentCourses
    }
    
    sql list(lastId: int, lastName: string, limit: int) {
        "
        WITH students AS ($include)
        SELECT * FROM students
        WHERE id > $lastId
        AND name > $lastName
        ORDER BY id DESC, name DESC
        LIMIT $limit
        "
    }
}

[crud get, list, save]
model Course for db {
    primary {
        id: int
    }
    
    column {
        title: string
    }
    
    nav (StudentCourse::courseId) {
        studentCourses
    }
}

[crud get, list, save]
model StudentCourse for db{
    primary {
        foreign (Student::id, Student::name) {
            studentId
            studentName
            
            nav {
                student
            }
        }
        
        foreign (Course::id) {
            courseId
        
            nav {
                course
            }
        }
    }
}

source Default for StudentCourse {
    include {}
}

source WithStudentCourse for StudentCourse {
    include {
        course {
            studentCourses
        }
        student {
            studentCourses
        }
    }
}