{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc"
  ],
  "categories": {
    "correctness": "error"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": [
    "**/dist/",
    "**/build/",
    "tests/e2e/fixtures/*/backend.ts",
    "tests/e2e/fixtures/*/client.ts",
    "tests/e2e/fixtures/**/*.json",
    "tests/e2e/fixtures/**/*.jsonc",
  ]
}